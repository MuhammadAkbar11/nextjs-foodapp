# Environment Configuration Template
#
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored and MUST NOT be committed.
# This `.env.example` file is committed as a template and MUST contain no secrets.

# ---------------------------------------------------------------------------
# Public / runtime configuration (safe to expose to the browser)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Server-only secrets (never expose to the browser)
# ---------------------------------------------------------------------------

# PostgreSQL connection URL (Issue 006 — Setup PostgreSQL Database)
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://foodapp_user:foodapp_password@localhost:5432/foodapp

# Authentication secret (future auth work)
# AUTH_SECRET=
